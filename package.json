{
  "name": "alete-gate-workspace",
  "version": "0.3.0",
  "private": true,
  "description": "Workspace for Alete Gate packages",
  "scripts": {
    "test": "pnpm -r test",
    "build": "pnpm -r build",
    "publish:ts": "pnpm publish -r --tag beta --no-git-checks",
    "publish:swift": "git tag -a v$npm_package_version -m \"Release v$npm_package_version\" && git push origin v$npm_package_version",
    "publish:all": "pnpm run publish:ts && pnpm run publish:swift",
    "synthesize": "tsx scripts/synthesize.js",
    "to-csv": "tsx scripts/to_csv.js",
    "curate": "tsx scripts/auto_curate.ts",
    "db:retrain-pipeline": "tsx scripts/retrain_pipeline.ts"
  },
  "author": "Stoyan Dimitrov <https://github.com/StoyanD>",
  "license": "AGPL-3.0",
  "keywords": [],
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.0.6",
      "onFail": "download"
    }
  },
  "type": "module",
  "dependencies": {
    "@alete-ai/gate-ingest": "workspace:*",
    "@mdream/js": "^1.1.1",
    "@mendable/firecrawl-js": "^4.24.1"
  },
  "devDependencies": {
    "@google/genai": "^2.8.0",
    "@types/node": "^25.8.0",
    "mongodb": "^7.2.0",
    "mongoose": "^9.6.3",
    "playwright": "^1.60.0",
    "tsup": "^8.5.1",
    "tsx": "^4.22.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.6"
  }
}
