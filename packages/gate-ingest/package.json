{
  "name": "@alete-ai/gate-ingest",
  "version": "2.1.0",
  "description": "Unified ingestion and token-mapping pipeline for the Alete PrivacyGatekeeper.",
  "keywords": [
    "edge",
    "crawler",
    "scraper",
    "firecrawl",
    "crawl4ai",
    "analysis"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "browser": "./dist/index.browser.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "browser": "./dist/index.browser.js",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@mdream/js": "^1.1.1"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
